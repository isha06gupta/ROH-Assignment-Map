:root {
      --bg: #0b0f1a; --card: #111827; --border: #1e2d45;
      --accent1: #f97316; --accent2: #38bdf8; --accent3: #a3e635; --accent4: #e879f9;
      --text: #e2e8f0; --muted: #64748b; --green: #22c55e; --red: #ef4444; --yellow: #facc15;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: var(--bg); color: var(--text); font-family: 'IBM Plex Sans', sans-serif; font-size: 14px; line-height: 1.6; }
    .hero { background: linear-gradient(135deg, #0b0f1a 0%, #0d1b2e 40%, #0a1628 100%); border-bottom: 1px solid var(--border); padding: 40px 48px 32px; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; top: -80px; right: -80px; width: 400px; height: 400px; background: radial-gradient(circle, rgba(249,115,22,.15) 0%, transparent 70%); }
    .hero-tag { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--accent1); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 10px; }
    .hero h1 { font-family: 'Rajdhani', sans-serif; font-size: 36px; font-weight: 700; color: #fff; line-height: 1.1; }
    .hero h1 span { color: var(--accent1); }
    .hero-sub { color: var(--muted); font-size: 13px; margin-top: 8px; max-width: 600px; }
    .hero-stats { display: flex; gap: 32px; margin-top: 24px; }
    .stat-val { font-family: 'Rajdhani', sans-serif; font-size: 28px; font-weight: 700; color: var(--accent2); }
    .stat-lbl { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }
    .main { max-width: 1200px; margin: 0 auto; padding: 40px 24px; }
    section { margin-bottom: 48px; }
    .section-title { font-family: 'Rajdhani', sans-serif; font-size: 20px; font-weight: 700; color: var(--accent2); text-transform: uppercase; letter-spacing: 1px; border-left: 3px solid var(--accent2); padding-left: 12px; margin-bottom: 20px; }
    .flow { display: flex; flex-direction: column; gap: 0; align-items: center; }
    .flow-row { display: flex; align-items: flex-start; gap: 12px; width: 100%; max-width: 900px; }
    .flow-node { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 14px 18px; flex: 1; }
    .flow-node.orange { border-color: var(--accent1); }
    .flow-node.blue { border-color: var(--accent2); }
    .flow-node.green { border-color: var(--accent3); }
    .flow-node.purple { border-color: var(--accent4); }
    .flow-node-title { font-family: 'Rajdhani', sans-serif; font-size: 15px; font-weight: 700; margin-bottom: 4px; }
    .flow-node.orange .flow-node-title { color: var(--accent1); }
    .flow-node.blue .flow-node-title { color: var(--accent2); }
    .flow-node.green .flow-node-title { color: var(--accent3); }
    .flow-node.purple .flow-node-title { color: var(--accent4); }
    .flow-node p { font-size: 12px; color: var(--muted); }
    .flow-arrow { display: flex; align-items: center; justify-content: center; color: var(--muted); font-size: 20px; padding: 4px 0; width: 100%; max-width: 900px; }
    .flow-branch { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; width: 100%; max-width: 900px; }
    .col-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 12px; }
    .col-card { background: var(--card); border: 1px solid var(--border); border-radius: 8px; padding: 14px 16px; display: flex; gap: 12px; align-items: flex-start; }
    .col-badge { font-family: 'IBM Plex Mono', monospace; font-size: 10px; padding: 3px 7px; border-radius: 4px; white-space: nowrap; flex-shrink: 0; margin-top: 1px; font-weight: 600; }
    .badge-id { background: rgba(249,115,22,.15); color: var(--accent1); border: 1px solid rgba(249,115,22,.3); }
    .badge-geo { background: rgba(56,189,248,.15); color: var(--accent2); border: 1px solid rgba(56,189,248,.3); }
    .badge-maint { background: rgba(163,230,53,.15); color: var(--accent3); border: 1px solid rgba(163,230,53,.3); }
    .badge-date { background: rgba(232,121,249,.15); color: var(--accent4); border: 1px solid rgba(232,121,249,.3); }
    .badge-status { background: rgba(250,204,21,.15); color: var(--yellow); border: 1px solid rgba(250,204,21,.3); }
    .badge-ops { background: rgba(34,197,94,.15); color: var(--green); border: 1px solid rgba(34,197,94,.3); }
    .col-info { flex: 1; }
    .col-name { font-family: 'IBM Plex Mono', monospace; font-size: 12px; color: var(--text); font-weight: 600; }
    .col-desc { font-size: 11px; color: var(--muted); margin-top: 3px; }
    .col-use { font-size: 11px; color: var(--accent2); margin-top: 4px; font-style: italic; }
    #map { width: 100%; height: 600px; border-radius: 10px; border: 1px solid var(--border); overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.22); }
    .map-wrapper { position: relative; }
    .map-overlay { position: absolute; z-index: 1200; color: var(--text); }
    .map-card { background: rgba(15,23,42,0.92); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 10px; box-shadow: 0 16px 40px rgba(0,0,0,0.28); }
    .map-card--small { max-width: 260px; }
    .map-card-title { font-size: 12px; font-weight: 700; letter-spacing: 0.03em; color: #f8fafc; margin-bottom: 8px; }
    .map-search-panel { top: 12px; left: 12px; width: 260px; }
    .map-quick-access { top: 12px; right: 12px; width: 150px; }
    .map-ranking-panel { bottom: 12px; right: 12px; width: 280px; max-height: 320px; overflow: hidden; }
    .map-floating-legend { bottom: 12px; left: 12px; width: 180px; }
    .quick-list { display: grid; gap: 6px; }
    .quick-link { width: 100%; text-align: left; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.08); color: #e2e8f0; padding: 8px 10px; border-radius: 8px; cursor: pointer; font-size: 12px; }
    .quick-link:hover { background: rgba(255,255,255,0.12); }
    .map-select { width: 100%; }
    .map-search { width: 100%; }
    .suggestion-list { margin-top: 8px; max-height: 180px; overflow-y: auto; background: rgba(15,23,42,0.98); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; }
    .suggestion-item { padding: 8px 10px; cursor: pointer; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 12px; }
    .suggestion-item:last-child { border-bottom: none; }
    .suggestion-item:hover { background: rgba(255,255,255,0.08); }
    .ranking-list { max-height: 240px; overflow-y: auto; }
    .ranking-row { display: flex; justify-content: space-between; gap: 8px; align-items: center; padding: 8px 10px; border-bottom: 1px solid rgba(255,255,255,0.08); font-size: 12px; cursor: pointer; }
    .ranking-row:last-child { border-bottom: none; }
    .ranking-row:hover { background: rgba(255,255,255,0.06); }
    .map-floating-legend .legend-item { margin-bottom: 6px; font-size: 12px; }
    .map-floating-legend .legend-item:last-child { margin-bottom: 0; }
    .map-card .legend-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 8px; vertical-align: middle; }
    .map-wrapper .map-card { pointer-events: auto; }
    .leaflet-container { background: #0f172a; }
    .zone-label { background: transparent; color: #111827; padding: 0 2px; border: 0; font-size: 12px; font-weight: 700; box-shadow: none; text-shadow: 0 0 2px rgba(255,255,255,0.8); white-space: nowrap; }
    .depot-label { background: transparent; color: #111827; font-size: 12px; font-weight: 700; text-shadow: 0 0 2px rgba(255,255,255,0.9); white-space: nowrap; padding: 1px 4px; pointer-events: none; }
    .map-card .map-card-title { margin-bottom: 10px; }
    .legend-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--muted); }
    .legend-dot { width: 12px; height: 12px; border-radius: 50%; }
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 12px; }
    th { font-family: 'IBM Plex Mono', monospace; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); padding: 8px 12px; border-bottom: 1px solid var(--border); text-align: left; }
    td { padding: 7px 12px; border-bottom: 1px solid rgba(255,255,255,.04); }
    tr:hover td { background: rgba(255,255,255,.02); }
    .bar-cell { width: 160px; }
    .bar { height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--accent2), var(--accent1)); }
    .count-high { color: var(--red); font-weight: 600; font-family: 'IBM Plex Mono', monospace; }
    .count-med { color: var(--yellow); font-weight: 600; font-family: 'IBM Plex Mono', monospace; }
    .count-low { color: var(--green); font-weight: 600; font-family: 'IBM Plex Mono', monospace; }
    .tabs { display: flex; gap: 4px; margin-bottom: 20px; flex-wrap: wrap; }
    .tab { padding: 7px 16px; border-radius: 6px; border: 1px solid var(--border); background: transparent; color: var(--muted); cursor: pointer; font-family: 'IBM Plex Sans', sans-serif; font-size: 12px; transition: .2s; }
    .tab.active { background: var(--accent1); color: #fff; border-color: var(--accent1); }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }
    .search { width: 100%; padding: 8px; border-radius: 6px; border: 1px solid rgba(255,255,255,0.04); background: transparent; color: var(--text); font-family: 'IBM Plex Sans', sans-serif; font-size: 12px; }
    .search::placeholder { color: var(--muted); }
    .btn { padding: 8px 10px; border-radius: 6px; border: 0; background: var(--accent1); color: #000; cursor: pointer; font-family: 'IBM Plex Sans', sans-serif; font-weight: 600; font-size: 12px; transition: .2s; }
    .btn:hover { opacity: 0.9; }
    .btn.secondary { background: transparent; border: 1px solid rgba(255,255,255,0.1); color: var(--muted); }
    .btn.secondary:hover { background: rgba(255,255,255,0.04); }
    .multi { max-height: 300px; overflow-y: auto; padding: 8px; border: 1px solid rgba(255,255,255,0.03); background: #071020; border-radius: 6px; }
    .depot-item { display: flex; align-items: center; gap: 8px; padding: 6px; border-bottom: 1px dashed rgba(255,255,255,0.02); }
    .depot-item input[type=checkbox] { cursor: pointer; }
    .depot-item label { cursor: pointer; }
    .kpi-row { display: flex; gap: 8px; margin-top: 12px; }
    .kpi { flex: 1; padding: 10px; border-radius: 6px; background: #071428; text-align: center; border: 1px solid rgba(255,255,255,0.05); }
    .small { font-size: 12px; color: var(--muted); }
